# --- Cliente (público) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# URL absoluta para Server Components que llaman a /api (opcional en local)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: segundos de vida de cookies de sesión Supabase en el navegador (por defecto ~1 año).
# Para que el JWT dure igual de largo, sube también «JWT expiry» en Supabase → Authentication → Settings.
# NEXT_PUBLIC_AUTH_COOKIE_MAX_AGE_SECONDS=31536000

# --- Solo servidor (Route Handlers bajo /api): Postgres en Supabase ---
# Si defines DATABASE_URL (completa), tiene prioridad sobre SUPABASE_DB_PASSWORD + SUPABASE_URL.
#
# Opción A (recomendada en Vercel y si ves timeouts / ECONNREFUSED en local):
# En Supabase → Settings → Database → Connection string, copia la URI del pooler:
# - «Transaction» (puerto 6543): la app usa `postgres` (postgres.js) con prepare:false y ?pgbouncer=true (se añade si falta).
# - «Session» (pooler): también válido; modo Transaction suele ser el recomendado en Vercel/serverless.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-....pooler.supabase.com:6543/postgres
#
# Opción B: sin DATABASE_URL, se construye conexión directa db.<ref>.supabase.co:5432 (requiere SUPABASE_DB_PASSWORD + SUPABASE_URL).
# Si /api devuelve 500 en desarrollo, prueba Opción A en .env.local y revisa el campo «detail» del JSON de error (solo NODE_ENV=development).
SUPABASE_DB_PASSWORD=your-postgres-password
SUPABASE_URL=https://YOUR_REF.supabase.co
# Opcional para NutriMax web: las rutas /api validan sesión con Supabase Auth (`getUser`), no con este secret.
# Mantén la variable si otros scripts o servicios del monorepo la necesitan.
# SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard
