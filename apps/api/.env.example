# Contraseña postgres (Dashboard → Database). Con SUPABASE_URL se construye la URI automáticamente.
SUPABASE_DB_PASSWORD=

# Opcional: si pones la URI completa aquí (sin placeholder), se ignora SUPABASE_DB_PASSWORD para la conexión.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

SUPABASE_URL=https://[REF].supabase.co
SUPABASE_REST_URL=https://[REF].supabase.co/rest/v1/
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWT_SECRET=your-jwt-secret-from-dashboard
SUPABASE_JWT_SIGNING_KEY_CURRENT=uuid-current-signing-key
SUPABASE_JWT_SIGNING_KEY_PREVIOUS=uuid-previous-signing-key
CORS_ORIGINS=http://localhost:3000
PORT=3001
